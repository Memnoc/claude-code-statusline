#!/usr/bin/env bash
# Statusline config CLI — works from terminal and `! statusline` inside Claude

CONF="$HOME/.claude/statusline.conf"

_sl_set() {
  local key="$1" val="$2" tmp="${CONF}.tmp"
  grep -v "^${key}=" "$CONF" 2>/dev/null > "$tmp"
  printf '%s="%s"\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$CONF"
}

_sl_get() {
  local key="$1"
  grep "^${key}=" "$CONF" 2>/dev/null | sed 's/.*="\(.*\)"/\1/'
}

_count_on_after() {
  local proposed_var="$1" proposed_val="$2"
  local count=0
  local all_segs="DIR GIT MODEL CTX RATE CACHE DURATION COST DIFF CAVEMAN"
  for seg in $all_segs; do
    local var="SEG_${seg}"
    local val
    if [ "$var" = "$proposed_var" ]; then
      val="$proposed_val"
    else
      val=$(_sl_get "$var")
      [ -z "$val" ] && val="on"
    fi
    [ "$val" = "on" ] && count=$((count + 1))
  done
  echo "$count"
}

[[ ! -f "$CONF" ]] && printf 'THEME="dawn"\nSIZE="full"\n' > "$CONF"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --theme)
      shift
      case "$1" in
        dawn|moon|main|catppuccin-latte|catppuccin-mocha|nord|gruvbox|tokyo-night|solarized) ;;
        *) echo "statusline: unknown theme '$1'. Run 'statusline --themes' for options." >&2; exit 1 ;;
      esac
      _sl_set THEME "$1"
      echo "statusline: theme → $1"
      ;;
    --themes)
      current=$(_sl_get THEME)
      [ -z "$current" ] && current="dawn"
      printf "%-20s %-6s %s\n" "Theme" "Mode" "Description"
      printf "%-20s %-6s %s\n" "-----" "----" "-----------"
      _theme_row() {
        local name="$1" mode="$2" desc="$3" marker=""
        [ "$name" = "$current" ] && marker=" *"
        printf "%-20s %-6s %s%s\n" "$name" "$mode" "$desc" "$marker"
      }
      _theme_row "dawn"             "light" "Rose Pine Dawn"
      _theme_row "moon"             "dark"  "Rose Pine Moon"
      _theme_row "main"             "dark"  "Rose Pine"
      _theme_row "catppuccin-latte" "light" "Catppuccin Latte"
      _theme_row "catppuccin-mocha" "dark"  "Catppuccin Mocha"
      _theme_row "nord"             "dark"  "Nord"
      _theme_row "gruvbox"          "dark"  "Gruvbox Dark"
      _theme_row "tokyo-night"      "dark"  "Tokyo Night"
      _theme_row "solarized"        "light" "Solarized Light"
      ;;
    --config)
      shift
      case "$1" in
        full|small|minimal) ;;
        *) echo "statusline: unknown config '$1'. Valid: full | small | minimal" >&2; exit 1 ;;
      esac
      _sl_set SIZE "$1"
      echo "statusline: config → $1"
      ;;
    --segment)
      shift
      name="${1%%:*}"
      state="${1##*:}"
      case "$name" in
        dir|git|model|ctx|rate|cache|duration|cost|diff|caveman) ;;
        *) echo "statusline: unknown segment '$name'." >&2
           echo "  Valid: dir git model ctx rate cache duration cost diff caveman" >&2
           exit 1 ;;
      esac
      case "$state" in
        on|off) ;;
        *) echo "statusline: state must be 'on' or 'off', got '$state'" >&2; exit 1 ;;
      esac
      var="SEG_$(echo "$name" | tr '[:lower:]' '[:upper:]')"
      if [ "$state" = "off" ]; then
        remaining=$(_count_on_after "$var" "off")
        if [ "$remaining" -lt 1 ]; then
          echo "statusline: cannot disable '$name' — at least one segment must remain on." >&2
          exit 1
        fi
      fi
      if [ "$state" = "on" ]; then
        # Remove the entry — "on" is the default, no need to store it
        local_tmp="${CONF}.tmp"
        grep -v "^${var}=" "$CONF" 2>/dev/null > "$local_tmp"
        mv "$local_tmp" "$CONF"
      else
        _sl_set "$var" "$state"
      fi
      echo "statusline: segment $name → $state"
      ;;
    --segments)
      echo "=== Segment visibility ==="
      for seg in dir git model ctx rate cache duration cost diff caveman; do
        var="SEG_$(echo "$seg" | tr '[:lower:]' '[:upper:]')"
        val=$(_sl_get "$var")
        [ -z "$val" ] && val="on"
        printf "  %-10s %s\n" "$seg" "$val"
      done
      ;;
    --show)
      echo "=== ~/.claude/statusline.conf ==="
      cat "$CONF" 2>/dev/null || echo "(empty — defaults active)"
      ;;
    --reset)
      printf 'THEME="dawn"\nSIZE="full"\n' > "$CONF"
      echo "statusline: reset to defaults (dawn / full / all segments on)"
      ;;
    --help|-h)
      cat <<'EOF'
Usage: statusline [options]

Theme:
  --theme <name>            Set active theme
  --themes                  List all available themes

Size preset:
  --config <name>           full | small | minimal

Segments:
  --segment <name>:<state>  Toggle a segment on or off
  --segments                Show all segment states

  Segment names: dir  git  model  ctx  rate  cache  duration  cost  diff  caveman
  At least one segment must remain on.

Other:
  --show                    Print current config file
  --reset                   Revert all settings to defaults
  --help                    This message
EOF
      ;;
    *)
      echo "statusline: unknown option '$1'. Try --help" >&2
      exit 1
      ;;
  esac
  shift
done
